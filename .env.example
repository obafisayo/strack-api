ENVIRONMENT=local
DEBUG=true

# Postgres
POSTGRES_USER=strack
POSTGRES_PASSWORD=strack
POSTGRES_DB=strack
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://strack:strack@db:5432/strack

# Auth
JWT_SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=

# YarnGPT (text-to-speech)
YARNGPT_API_KEY=
YARNGPT_API_BASE_URL=https://yarngpt.ai/api/v1/tts

# Media
MEDIA_ROOT=static
MEDIA_URL=/media
BASE_URL=http://localhost:8000

# CORS
CORS_ORIGINS=*
